{
  "name": "lena",
  "module": "index.ts",
  "type": "module",
  "workspaces": [
    "./apps/*",
    "./packages/*"
  ],
  "scripts": {
    "backend:start": "NODE_ENV=production && bun apps/backend/src/index.ts",
    "backend:dev": "NODE_ENV=development && bun --watch apps/backend/src/index.ts",
    "backend:build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile dist/server apps/backend/src/index.ts",
    "ims:start": "NODE_ENV=production && bun apps/ims/src/index.ts",
    "ims:dev": "NODE_ENV=development && bun --watch apps/ims/src/index.ts",
    "ims:build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile dist/ims apps/ims/src/index.ts",
    "frontend:start": "cd apps/frontend && bun --env-file=../.env nuxt start",
    "frontend:dev": "bun --env-file=../../.env --cwd=apps/frontend nuxt dev",
    "frontend:build": "cd apps/frontend && nuxt build",
    "databases:generate": "bun prisma generate --schema=packages/app-db/prisma/schema.prisma && bun prisma generate --schema=packages/ims-db/prisma/schema.prisma",
    "databases:push": "bun prisma db push --config=packages/app-db/prisma.config.ts && bun prisma db push --config=packages/ims-db/prisma.config.ts",
    "databases:pull": "bun prisma db pull --config=packages/app-db/prisma.config.ts && bun prisma db pull --config=packages/ims-db/prisma.config.ts",
    "proto:generate": "find ./packages/proto/src -name \"*.proto\" -exec proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --grpcLib=@grpc/grpc-js -O ./packages/proto/dist {} +",
    "lint": "eslint"
  },
  "devDependencies": {
    "@grpc/proto-loader": "^0.8.0",
    "@types/bun": "latest",
    "dotenv": "^17.4.2",
    "prisma": "^7.7.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}