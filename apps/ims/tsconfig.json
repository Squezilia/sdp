{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@sdp/backend/*": ["src/*"],
      "@sdp/config/*": ["../../packages/config/src/*"],

      "@sdp/ims-db": ["../../packages/ims-db/src/index.ts"],
      "@sdp/ims-db/*": ["../../packages/ims-db/src/*"],
      "@sdp/ims-db/prismabox": [
        "../../packages/ims-db/src/generated/prismabox/barrel.ts"
      ],
      "@sdp/ims-db/prisma": [
        "../../packages/ims-db/src/generated/prisma/client.ts"
      ],

      "@sdp/proto": ["../../packages/proto/src/index.ts"],
      "@sdp/proto/generated/*": ["../../packages/proto/dist/*"]
    }
  },
  "include": ["src"]
}
